# =============================================================================
# MPDPMS Backend — Environment Variables Template
# =============================================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in every value marked <REQUIRED>
# 3. NEVER commit .env to version control
# =============================================================================


# ── Database ──────────────────────────────────────────────────────────────────
# <REQUIRED>  Full PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/mpdpms

# Used by docker-compose to create the postgres service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<change_me>


# ── Authentication ─────────────────────────────────────────────────────────────
# <REQUIRED>  Must be at least 32 characters in production.
# Generate:   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# <REQUIRED>  Admin account seeded on first startup
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=<min_8_chars_not_admin123>

# Admin seed metadata (optional — defaults shown)
ADMIN_SEED_ROLE=Project Manager
ADMIN_SEED_FULL_NAME=Admin


# ── Redis / Celery (optional — required for async workers) ────────────────────
# Enables rate-limiting store (SECURITY_STORE_BACKEND=redis) and Celery tasks
REDIS_URL=redis://localhost:6379/0

# Override individual Celery transport/backend (defaults to REDIS_URL)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=


# ── External integrations (all optional) ──────────────────────────────────────
# Anthropic Claude API — enables AI assistant feature
ANTHROPIC_API_KEY=

# Alerting webhook (Slack, Teams, PagerDuty …)
ALERT_WEBHOOK_URL=

# ── Observability (Sentry + OpenTelemetry) — both no-op if unset ──────────────
# Sentry: error tracking + performance. Leave SENTRY_DSN empty to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# OpenTelemetry: distributed tracing. Leave OTEL_EXPORTER_OTLP_ENDPOINT empty
# to disable. Point at Tempo / Honeycomb / Jaeger / Datadog OTLP receiver.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=mpdpms-api


# ── Application behaviour ──────────────────────────────────────────────────────
# Run Alembic migrations on startup (true) or skip (false)
AUTO_MIGRATE=true
# Bootstrap raw schema.sql instead of migrations (mutually exclusive with AUTO_MIGRATE)
BOOTSTRAP_SCHEMA=false
# Enforce HSTS header — set true in production (requires JWT_SECRET to be set)
ENABLE_HSTS=true

# Logging
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_JSON=true           # true = JSON lines (production), false = human-readable (dev)

# Rate-limiting backend: "memory" (single-process) or "redis" (multi-instance)
SECURITY_STORE_BACKEND=memory

# Maximum uploaded report file size in bytes (default 25 MB)
MAX_REPORT_SIZE_BYTES=26214400

# Advisory lock ID used during schema bootstrap to avoid race conditions
SCHEMA_BOOTSTRAP_LOCK_ID=987654321

# Frontend HTML filename served at /
FRONTEND_FILENAME=MetalFlowPro_v3_1.html


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# ── Session & token tuning ────────────────────────────────────────────────────
JWT_EXP_H=1               # Access token lifetime in hours
REFRESH_EXP_DAYS=14       # Refresh token lifetime in days
LOGIN_MAX_ATTEMPTS=5      # Brute-force threshold before lockout
LOGIN_WINDOW_S=60         # Lockout window in seconds


# ── Metallurgical defaults (used when project data is absent) ─────────────────
DEFAULT_ORE_SG=2.75
DEFAULT_RECOVERY_PCT=89.0
DEFAULT_AVAILABILITY_PCT=92.0
DEFAULT_OPERATING_HOURS_DAY=24.0
DEFAULT_ENERGY_RATE=0.08              # USD/kWh
DEFAULT_NACN_PRICE=3.50              # USD/kg
DEFAULT_CAO_PRICE=0.12               # USD/kg
DEFAULT_AUX_ENERGY_KWH_T=5.0
DEFAULT_SAG_SPECIFIC_ENERGY=8.0      # kWh/t
DEFAULT_BM_SPECIFIC_ENERGY=7.0       # kWh/t
DEFAULT_NACN_CONSUMPTION_KG_T=0.5
DEFAULT_CAO_CONSUMPTION_KG_T=1.2


# ── ESG / Carbon ──────────────────────────────────────────────────────────────
GRID_CO2_KG_KWH=0.50      # kg CO₂ per kWh — update for your grid
WGC_CO2_BENCHMARK=800     # WGC benchmark t CO₂/oz Au
